rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // History collections: authenticated users can read/write their own records
    match /aptitude_history/{docId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid) && request.resource.data.uid == request.auth.uid;
    }
    
    match /technical_history/{docId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid) && request.resource.data.uid == request.auth.uid;
    }
    
    match /hr_history/{docId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid) && request.resource.data.uid == request.auth.uid;
    }
    
    // Classes, assignments, attendance: authenticated users can access
    match /classes/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /assignments/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /attendance/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
